# =============================================================================
# Hokora — .gitignore
# Organised by axis so each section can be extended independently.
# =============================================================================

# -----------------------------------------------------------------------------
# Python build / packaging
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
*.whl
*.manifest
*.spec
MANIFEST
pip-wheel-metadata/
pip-log.txt
pip-delete-this-directory.txt
share/python-wheels/
# Compiled C extensions (defensive — sqlcipher3 builds these into the
# venv's site-packages, but a setup.py develop outside a venv could
# leave them in src/).
*.so
*.dylib
*.dll
*.pyd

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.python-version
.tool-versions

# -----------------------------------------------------------------------------
# Type checkers, linters, test caches
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/
.pytest_cache/
.ruff_cache/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Coverage
# -----------------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
coverage.json
coverage.lcov
htmlcov/

# -----------------------------------------------------------------------------
# Test output
# -----------------------------------------------------------------------------
junit.xml
junit-*.xml
pytest-junit.xml
pytest-results.xml
test-results/
test-results.xml

# -----------------------------------------------------------------------------
# Profiling
# -----------------------------------------------------------------------------
*.prof
*.lprof
*.pstats

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.code-workspace
.history/
.fleet/
.spyderproject
.spyproject
.ipynb_checkpoints/
*.swp
*.swo
*.swn
*~
.#*
\#*\#
*.iml
*.sublime-project
*.sublime-workspace
Session.vim
Sessionx.vim
tags
TAGS
.tags
cscope.*

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
._*
.AppleDouble
.LSOverride
Icon
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Secrets and environment
# -----------------------------------------------------------------------------
.env
.env.*
.envrc
.direnv/
# Common credential / key file patterns — defensive. Hokora doesn't
# emit any of these; the rule exists so an operator who accidentally
# drops a private key into the repo doesn't ship it.
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.kdbx
*.gpg
*.asc
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
id_dsa
id_dsa.*
.netrc
.pgpass
secrets.json
secrets.yaml
secrets.yml
*.secrets

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
*.log.[0-9]*

# -----------------------------------------------------------------------------
# Database files (SQLCipher / SQLite)
# -----------------------------------------------------------------------------
*.db
*.db-shm
*.db-wal
*.db.*
*.sqlite
*.sqlite3
*.sqlite-journal

# -----------------------------------------------------------------------------
# Hokora runtime artifacts — daemon
# Generated by `hokora init` and the running daemon. Defends against a
# developer running `hokora init --data-dir .` from inside the repo.
# -----------------------------------------------------------------------------
hokora.toml
api_key
db_key
heartbeat
hokorad.argv
*.pid
/identities/
/media/
/lxmf/
/lxmf_node/
*.ratchets
.hokora/

# -----------------------------------------------------------------------------
# Hokora runtime artifacts — TUI client
# -----------------------------------------------------------------------------
client_identity
node_identity
.hokora-client/

# -----------------------------------------------------------------------------
# Common local data-dir names (volume mounts, dev workspaces)
# -----------------------------------------------------------------------------
data/
data-relay/
hokora-data/
hokora-relay-data/

# -----------------------------------------------------------------------------
# Docker overrides (operator-local; never commit)
# -----------------------------------------------------------------------------
docker-compose.override.yml
compose.override.yml
compose.local.yml
*.tar

# -----------------------------------------------------------------------------
# Test runtime state (RNS)
# RNS writes <configdir>/storage/{cache,identities,resources,announces}
# on every run. The configs themselves are tracked; the storage trees
# under each config are not.
# -----------------------------------------------------------------------------
tests/live/rns_a/storage/
tests/live/rns_b/storage/
tests/live/docker_rns_a/storage/
tests/live/docker_rns_b/storage/
tests/live/rns_a/interfaces/__pycache__/
tests/live/rns_b/interfaces/__pycache__/

# -----------------------------------------------------------------------------
# Backup / scratch
# -----------------------------------------------------------------------------
*.bak
*.orig
*.rej
*.tmp
